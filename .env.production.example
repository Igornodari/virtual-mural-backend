# ─────────────────────────────────────────────────────────────────────────────
# VARIÁVEIS DE AMBIENTE — PRODUÇÃO (Railway)
# Copie este arquivo, preencha os valores e configure no painel do Railway
# NÃO commite este arquivo com valores reais no Git
# ─────────────────────────────────────────────────────────────────────────────

# ─── Aplicação ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# PORT é injetado automaticamente pelo Railway — não precisa definir

# ─── Banco de Dados (Railway PostgreSQL Plugin) ───────────────────────────────
# O Railway injeta automaticamente DATABASE_URL quando você adiciona o plugin PostgreSQL
# Use a variável abaixo OU configure DB_* separadamente
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Alternativa: variáveis individuais (se não usar DATABASE_URL)
DB_HOST=your-railway-postgres-host.railway.internal
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_NAME=railway
DB_SYNC=false   # ← NUNCA deixar true em produção!

# ─── AWS Cognito ─────────────────────────────────────────────────────────────
AWS_REGION=sa-east-1
COGNITO_USER_POOL_ID=sa-east-1_NiMyy2V3k
COGNITO_CLIENT_ID=3m3i285a6d5tlje7h3p4t1ueu2

# ─── RabbitMQ (CloudAMQP — plano gratuito: cloudamqp.com) ────────────────────
RABBITMQ_URL=amqps://user:password@your-instance.cloudamqp.com/vhost
RABBITMQ_QUEUE=virtual_mural_queue

# ─── AWS SNS (Notificações) ──────────────────────────────────────────────────
SNS_CONDOMINIUM_TOPIC_ARN=arn:aws:sns:sa-east-1:SEU_ACCOUNT_ID:virtual-mural-condominium

# ─── AWS SES (E-mails) ───────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@seudominio.com.br
# Credenciais AWS (se não usar IAM Role)
AWS_ACCESS_KEY_ID=sua-access-key
AWS_SECRET_ACCESS_KEY=seu-secret

# ─── CORS — URL do frontend na Vercel ────────────────────────────────────────
CORS_ORIGIN=https://seu-projeto.vercel.app

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # Chave live do Stripe (produção)
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...        # Gere no painel Stripe → Webhooks
PAYMENT_GATEWAY_PROVIDER=stripe

# ─── Log ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=warn
