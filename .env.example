# ─── Aplicação ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=virtual_mural
DB_SYNC=true

# ─── AWS Cognito ─────────────────────────────────────────────────────────────
AWS_REGION=sa-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=virtual_mural_queue

# ─── AWS SNS ─────────────────────────────────────────────────────────────────
SNS_CONDOMINIUM_TOPIC_ARN=

# ─── AWS SES ─────────────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@virtual-mural.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Em produção, usar a URL real do frontend. Ex: https://app.virtual-mural.com
CORS_ORIGIN=http://localhost:4200

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Chaves de TESTE: sk_test_... / pk_test_...
# Chaves de PRODUÇÃO: sk_live_... / pk_live_...
# NUNCA commitar chaves reais neste arquivo
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
PAYMENT_GATEWAY_PROVIDER=stripe

# ─── Stripe Connect ──────────────────────────────────────────────────────────
STRIPE_CONNECT_RETURN_URL=http://localhost:4200/mural/provider?stripe_connect=success
STRIPE_CONNECT_REFRESH_URL=http://localhost:4200/mural/provider?stripe_connect=refresh
PLATFORM_FEE_PERCENT=5

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Gerar com: npx web-push generate-vapid-keys
LOG_LEVEL=warn
VAPID_SUBJECT=mailto:admin@virtual-mural.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
