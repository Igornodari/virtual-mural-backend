# ─── Aplicação ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de Dados (PostgreSQL / AWS RDS) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=virtual_mural
DB_SYNC=true          # false em produção; use migrações

# ─── AWS Cognito ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# URL do JWKS gerado automaticamente a partir do User Pool ID
# https://cognito-idp.{region}.amazonaws.com/{userPoolId}/.well-known/jwks.json

# ─── RabbitMQ (Amazon MQ / local) ────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=virtual_mural_queue

# ─── AWS SNS (Notificações para moradores) ───────────────────────────────────
# ARN do tópico SNS padrão do condomínio (em produção, um tópico por condomínio)
SNS_CONDOMINIUM_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:virtual-mural-condominium

# ─── AWS SES (E-mails transacionais) ─────────────────────────────────────────
# E-mail remetente verificado no SES (deve estar verificado na conta AWS)
SES_FROM_EMAIL=noreply@virtual-mural.com

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200
